# ---- サーバ ----
# 本番は production（SECRET/ADMIN_PASS が初期値だと起動を中止する）
NODE_ENV=development
PORT=3000
# 外部公開URL（末尾スラッシュなし）。claim/計測リンクの生成に使用。
BASE_URL=https://example.ngrok-free.app
# ログレベル: debug | info | warn | error
LOG_LEVEL=info

# ---- 運営(operator)アカウント（初回起動時に自動作成）----
# /operator にログインしてテナント(院)を管理する
OPERATOR_EMAIL=admin@example.com
OPERATOR_PASSWORD=change-me-strong

# ---- 署名/暗号化シークレット（JWT・claim署名・テナント機微情報のAES鍵を派生）----
# 十分に長いランダム文字列にすること: openssl rand -hex 32
# ※変更するとログインセッションと保存済みの暗号化トークンが無効になるため運用後は固定
SECRET=please-change-this-to-a-long-random-string

# ---- サブスク（トライアル・既定プラン）----
TRIAL_DAYS=14
PLAN_NAME=スタンダード
PLAN_AMOUNT=4980

# ---- UnivaPay 定期課金 ----
# 認証は単一のApp Token(JWT)のみ（Bearer {jwt}）。ドメイン単位で発行され、
# JWTペイロードに domains:[...] としてそのアプリの許可ドメインがエンコードされる
# （例:他ドメイン用に発行したトークンはこのドメインでは使えない）。
UNIVAPAY_ENABLED=false
UNIVAPAY_JWT_TOKEN=
UNIVAPAY_STORE_ID=
# Webhook署名(HMAC-SHA256)検証用の鍵。UnivaPay管理画面のWebhook設定から取得・設定する
UNIVAPAY_WEBHOOK_SECRET=
UNIVAPAY_CURRENCY=jpy
UNIVAPAY_PERIOD=monthly

# ---- 紐づけの時間窓（秒, 既定値）----
# 院ごとにダッシュボードで上書き可能
MATCH_WINDOW_SEC=1800

# 注: LINE / Meta / TikTok の各認証情報は「院（テナント）ごと」にダッシュボードで設定します。
#     （AES-256-GCMで暗号化してDB保存。env でのグローバル設定は不要）

# ---- ポストバック リトライ ----
POSTBACK_MAX_ATTEMPTS=5
POSTBACK_RETRY_SEC=60

# ---- データ保持（個人情報の自動削除）----
# RETENTION_DAYS 日より古い clicks/follows/postbacks を定期削除。0以下で無効。
RETENTION_DAYS=90
RETENTION_INTERVAL_SEC=21600

# ---- バックアップ（scripts/backup.js）----
BACKUP_DIR=./data/backups
BACKUP_KEEP=14

# ---- レート制限（公開エンドポイント /c /webhook /claim）----
RATE_LIMIT_WINDOW_SEC=60
RATE_LIMIT_MAX=120

# ---- DB（省略時 ./data/keiro.db）----
DB_PATH=./data/keiro.db
